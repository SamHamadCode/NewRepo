<Window x:Class="MonitorBot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MonitorBot.App.Views"
        xmlns:vm="clr-namespace:MonitorBot.App.ViewModels"
        Title="MonitorBot" Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeep}"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- DataTemplate routing: CurrentView → appropriate UserControl -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TasksViewModel}">
            <views:TasksView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfilesViewModel}">
            <views:ProfilesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccountsViewModel}">
            <views:AccountsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ──────────────────────────── -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo / Brand -->
                <Border DockPanel.Dock="Top" Padding="20,20,20,16"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="MonitorBot" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"/>
                        <TextBlock Text="v1.0.0" Style="{StaticResource TextCaption}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Import / Export -->
                <Border DockPanel.Dock="Bottom" Padding="12,8"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Content="📤 Export Config" Style="{StaticResource NavButton}"
                                Command="{Binding ExportCommand}" HorizontalContentAlignment="Left"/>
                        <Button Content="📥 Import Config" Style="{StaticResource NavButton}"
                                Command="{Binding ImportCommand}" HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <StackPanel DockPanel.Dock="Top" Margin="8,8,8,0">
                    <Button Content="🏠  Dashboard"  Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                            HorizontalContentAlignment="Left"/>
                    <Button Content="📋  Tasks"      Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Tasks"
                            HorizontalContentAlignment="Left"/>
                    <Button Content="👤  Profiles"   Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Profiles"
                            HorizontalContentAlignment="Left"/>
                    <Button Content="🔑  Accounts"   Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Accounts"
                            HorizontalContentAlignment="Left"/>
                    <Button Content="📜  Logs"       Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Logs"
                            HorizontalContentAlignment="Left"/>
                    <Button Content="⚙️  Settings"   Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"
                            HorizontalContentAlignment="Left"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main Content ─────────────────────── -->
        <Border Grid.Column="1" Background="{StaticResource BgPanel}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>
