<Window x:Class="MonitorBot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:MonitorBot.App.Views"
        xmlns:vm="clr-namespace:MonitorBot.App.ViewModels"
        Title="NexusBot" Height="720" Width="1180"
        MinHeight="580" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="{StaticResource BgDeep}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TasksViewModel}"><views:TasksView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfilesViewModel}"><views:ProfilesView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccountsViewModel}"><views:AccountsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}"><views:LogsView/></DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Title Bar ──────────────────────────────────────────────── -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo mark -->
                    <Border Grid.Column="0" Width="60" Background="{StaticResource BgSidebar}">
                        <TextBlock Text="N" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- App title + version -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="NEXUSBOT" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Text="v1.0" FontSize="10" Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource WinCtrlButton}" Content="─"
                                Click="MinimizeButton_Click" ToolTip="Minimize"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Style="{StaticResource WinCtrlButton}" Content="□"
                                Click="MaximizeButton_Click" ToolTip="Maximize"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Style="{StaticResource CloseButton}" Content="✕"
                                Click="CloseButton_Click" ToolTip="Close"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Sidebar ─────────────────────────────────────────────────── -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource BgSidebar}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Bottom: import/export -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                        <Button Style="{StaticResource NavButton}" ToolTip="Export Config"
                                Command="{Binding ExportCommand}" Content="📤"/>
                        <Button Style="{StaticResource NavButton}" ToolTip="Import Config"
                                Command="{Binding ImportCommand}" Content="📥"/>
                    </StackPanel>

                    <!-- Nav icons -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                        <Button ToolTip="Dashboard"
                                Style="{Binding CurrentPage, Converter={StaticResource NavStyleSelector}, ConverterParameter=Dashboard}"
                                Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                Content="⊞"/>
                        <Button ToolTip="Tasks"
                                Style="{Binding CurrentPage, Converter={StaticResource NavStyleSelector}, ConverterParameter=Tasks}"
                                Command="{Binding NavigateCommand}" CommandParameter="Tasks"
                                Content="☰"/>
                        <Button ToolTip="Profiles"
                                Style="{Binding CurrentPage, Converter={StaticResource NavStyleSelector}, ConverterParameter=Profiles}"
                                Command="{Binding NavigateCommand}" CommandParameter="Profiles"
                                Content="👤"/>
                        <Button ToolTip="Accounts"
                                Style="{Binding CurrentPage, Converter={StaticResource NavStyleSelector}, ConverterParameter=Accounts}"
                                Command="{Binding NavigateCommand}" CommandParameter="Accounts"
                                Content="🔑"/>
                        <Button ToolTip="Logs"
                                Style="{Binding CurrentPage, Converter={StaticResource NavStyleSelector}, ConverterParameter=Logs}"
                                Command="{Binding NavigateCommand}" CommandParameter="Logs"
                                Content="📋"/>
                        <Button ToolTip="Settings"
                                Style="{Binding CurrentPage, Converter={StaticResource NavStyleSelector}, ConverterParameter=Settings}"
                                Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                Content="⚙"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Main Content ──────────────────────────────────────────────── -->
            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource BgPanel}">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>
        </Grid>
    </Border>
</Window>
