<Window x:Class="MonitorBot.App.Views.CookieHarvesterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Cookie Harvester"
        Height="720" Width="1100"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#0A0A0F">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="#0F0F15"
                BorderBrush="#1E1E2E" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#00C8FF" Margin="0,0,10,0"/>
                    <TextBlock Text="Cookie Harvester" FontSize="13" FontWeight="SemiBold"
                               Foreground="#E2E8F0"/>
                    <TextBlock x:Name="SiteLabel" FontSize="12" Foreground="#64748B"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="28" Height="28" BorderThickness="0"
                        Background="Transparent" Foreground="#94A3B8"
                        FontSize="14" Content="&#x2715;"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="{TemplateBinding Content}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EF4444"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#0F0F15"
                BorderBrush="#1E1E2E" BorderThickness="0,0,0,1"
                Padding="12,0">
            <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#64748B" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Log in to the site below &#x2014; cookies will be harvested automatically."
                               FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="&#x2714;  Harvest &amp; Apply"
                        Height="28" Padding="14,0"
                        Click="HarvestButton_Click"
                        Background="#00C8FF" Foreground="#0A0A0F"
                        FontSize="12" FontWeight="SemiBold" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#00A8D8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- WebView2 embedded browser -->
        <wv2:WebView2 x:Name="WebBrowser" Grid.Row="2"/>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#0F0F15"
                BorderBrush="#1E1E2E" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock FontSize="10" Foreground="#475569" TextWrapping="Wrap">
                Log into the site as normal, then click
                <Run FontWeight="SemiBold" Foreground="#00C8FF">Harvest &amp; Apply</Run>
                &#x2014; all session cookies are extracted and applied to your task automatically.
                Re-harvest every few minutes as Akamai cookies expire quickly.
            </TextBlock>
        </Border>
    </Grid>
</Window>
