<UserControl x:Class="MonitorBot.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar List -->
        <DockPanel Grid.Column="0" Margin="24,24,0,24">
            <StackPanel DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                <TextBlock Text="Profiles" Style="{StaticResource TextH1}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="+" Style="{StaticResource PrimaryButton}" Width="32"
                        Command="{Binding AddCommand}"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                     DisplayMemberPath="Name"/>
        </DockPanel>

        <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right" Fill="{StaticResource Border}"/>

        <!-- Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" IsEnabled="{Binding IsEditing}">
                <TextBlock Text="Profile Details" Style="{StaticResource SectionHeader}"/>

                <!-- Basic Info -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Style="{StaticResource FormRow}">
                        <TextBlock Text="First Name" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Style="{StaticResource FormRow}">
                        <TextBlock Text="Last Name" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.LastName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Email" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Email, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Phone" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Phone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Shipping Address -->
                <TextBlock Text="Shipping Address" Style="{StaticResource TextH2}" Margin="0,8,0,12"/>
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Address Line 1" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.ShippingAddress.Line1, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Address Line 2" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.ShippingAddress.Line2, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="80"/><ColumnDefinition Width="12"/><ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="City" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.ShippingAddress.City, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="State" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.ShippingAddress.State, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="ZIP" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.ShippingAddress.ZipCode, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Country" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.ShippingAddress.Country, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Payment -->
                <TextBlock Text="Payment" Style="{StaticResource TextH2}" Margin="0,8,0,12"/>
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Card Number" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Payment.CardNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Exp Month" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.Payment.ExpiryMonth, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Exp Year" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.Payment.ExpiryYear, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="CVV" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.Payment.Cvv, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Save Profile" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
