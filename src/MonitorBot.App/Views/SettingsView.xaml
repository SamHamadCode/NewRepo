<UserControl x:Class="MonitorBot.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Page header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Settings" Style="{StaticResource TextH1}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Save" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
                    <Button Content="Reset to Defaults" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- General -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="GENERAL" Style="{StaticResource TextLabel}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DEFAULT INTERVAL (S)" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding Current.DefaultIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MAX CONCURRENT TASKS" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding Current.MaxConcurrentTasks, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="LICENSE KEY" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding Current.LicenseKey, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox Content="Auto-start tasks on launch" Margin="0,0,20,8"
                                      IsChecked="{Binding Current.AutoStartTasks}"/>
                            <CheckBox Content="Minimize to tray" Margin="0,0,20,8"
                                      IsChecked="{Binding Current.MinimizeToTray}"/>
                            <CheckBox Content="Launch on system startup" Margin="0,0,20,8"
                                      IsChecked="{Binding Current.LaunchOnStartup}"/>
                            <CheckBox Content="Auto-update" Margin="0,0,20,8"
                                      IsChecked="{Binding Current.AutoUpdate}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Captcha -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="CAPTCHA" Style="{StaticResource TextLabel}" Margin="0,0,0,14"/>
                        <StackPanel Style="{StaticResource FormRow}">
                            <TextBlock Text="2CAPTCHA API KEY" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Current.TwoCaptchaApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <TextBlock Text="Sign up at 2captcha.com - ~$3 per 1,000 solves. Leave blank to skip."
                                   Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>

                <!-- Browser Integration -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="BROWSER INTEGRATION" Style="{StaticResource TextLabel}" Margin="0,0,0,14"/>
                        <CheckBox Content="Use browser session (Chrome / Brave)" Margin="0,0,0,12"
                                  IsChecked="{Binding Current.UseBrowserSession}"/>
                        <StackPanel Style="{StaticResource FormRow}">
                            <TextBlock Text="REMOTE DEBUG PORT" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Current.BrowserExtensionPort, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Notifications -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="DESKTOP NOTIFICATIONS" Style="{StaticResource TextLabel}" Margin="0,0,0,14"/>
                        <WrapPanel>
                            <CheckBox Content="Enable desktop notifications" Margin="0,0,20,8"
                                      IsChecked="{Binding Current.Notifications.DesktopEnabled}"/>
                            <CheckBox Content="Notify on success" Margin="0,0,20,8"
                                      IsChecked="{Binding Current.Notifications.DesktopOnSuccess}"/>
                            <CheckBox Content="Notify on failure"
                                      IsChecked="{Binding Current.Notifications.DesktopOnFailure}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Webhooks -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="WEBHOOKS" Style="{StaticResource TextLabel}"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button Content="+" Style="{StaticResource PrimaryButton}"
                                        Width="26" Height="26" Padding="0"
                                        Command="{Binding AddWebhookCommand}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Webhooks}"
                                     SelectedItem="{Binding SelectedWebhook, Mode=TwoWay}"
                                     DisplayMemberPath="Name"/>
                        </DockPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource Border}"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Grid.Column="2"
                                    IsEnabled="{Binding SelectedWebhook, Converter={StaticResource NullToBool}}">
                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Text="NAME" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding SelectedWebhook.Name, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Text="CHANNEL" Style="{StaticResource TextLabel}"/>
                                <ComboBox SelectedItem="{Binding SelectedWebhook.Channel}"
                                          ItemsSource="{Binding Source={StaticResource NotificationChannelValues}}"/>
                            </StackPanel>
                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Text="WEBHOOK URL" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding SelectedWebhook.Url, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <WrapPanel Margin="0,0,0,12">
                                <CheckBox Content="Enabled" Margin="0,0,16,0"
                                          IsChecked="{Binding SelectedWebhook.IsEnabled}"/>
                                <CheckBox Content="On Success" Margin="0,0,16,0"
                                          IsChecked="{Binding SelectedWebhook.OnSuccess}"/>
                                <CheckBox Content="On Failure"
                                          IsChecked="{Binding SelectedWebhook.OnFailure}"/>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Test" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding TestWebhookCommand}" Margin="0,0,8,0"/>
                                <Button Content="Delete" Style="{StaticResource DangerButton}"
                                        Command="{Binding DeleteWebhookCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Logging -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="LOGGING" Style="{StaticResource TextLabel}" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="LOG LEVEL" Style="{StaticResource TextLabel}"/>
                                <ComboBox SelectedItem="{Binding Current.LogLevel}"
                                          ItemsSource="{Binding Source={StaticResource LogLevelValues}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="RETENTION (DAYS)" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding Current.LogRetentionDays, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
