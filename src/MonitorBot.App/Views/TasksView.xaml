<UserControl x:Class="MonitorBot.App.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MonitorBot.App.ViewModels">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Task List -->
        <DockPanel Grid.Column="0" Margin="24,24,12,24">

            <!-- Toolbar -->
            <StackPanel DockPanel.Dock="Top" Style="{StaticResource Toolbar}">
                <TextBlock Text="Tasks" Style="{StaticResource TextH1}" VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <Button Content="+ Add" Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddCommand}" Margin="0,0,6,0"/>
                <Button Content="? Start" Style="{StaticResource SuccessButton}"
                        Command="{Binding StartCommand}" Margin="0,0,6,0"/>
                <Button Content="? Stop" Style="{StaticResource SecondaryButton}"
                        Command="{Binding StopCommand}" Margin="0,0,6,0"/>
                <Button Content="?? All" Style="{StaticResource SuccessButton}"
                        Command="{Binding StartAllCommand}" Margin="0,0,6,0"/>
                <Button Content="?? All" Style="{StaticResource SecondaryButton}"
                        Command="{Binding StopAllCommand}" Margin="0,0,6,0"/>
                <Button Content="?? Delete" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>

            <!-- Grid -->
            <DataGrid ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      IsReadOnly="True"
                      SelectionUnit="FullRow"
                      DockPanel.Dock="Top">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"                               Width="*"/>
                    <DataGridTextColumn Header="TYPE"     Binding="{Binding Type}"                               Width="80"/>
                    <DataGridTextColumn Header="INTERVAL" Binding="{Binding IntervalSeconds, StringFormat={}{0}s}" Width="70"/>
                    <DataGridTemplateColumn Header="STATUS" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource StatusBadge}"
                                        Background="{Binding StatusColor}"
                                        HorizontalAlignment="Left"
                                        Margin="4,6">
                                    <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="LAST RESULT" Binding="{Binding LastResult}"                       Width="100"/>
                    <DataGridTextColumn Header="LAST CHECK"  Binding="{Binding LastChecked, StringFormat={}{0:HH:mm:ss}}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Divider -->
        <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right"
                   Fill="{StaticResource Border}"/>

        <!-- Right: Task Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,24,24,24"
                        IsEnabled="{Binding Selected, Converter={StaticResource NullToBool}}">
                <TextBlock Text="Edit Task" Style="{StaticResource TextH2}" Margin="0,0,0,16"/>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Name" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Name, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Target URL" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.TargetUrl, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Monitor Type" Style="{StaticResource TextLabel}"/>
                    <ComboBox SelectedItem="{Binding Selected.Type}"
                              ItemsSource="{Binding Source={StaticResource MonitorTypeValues}}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Detection Mode" Style="{StaticResource TextLabel}"/>
                    <ComboBox SelectedItem="{Binding Selected.DetectionMode}"
                              ItemsSource="{Binding Source={StaticResource DetectionModeValues}}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="SKU (optional)" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Sku, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Keyword (optional)" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Keyword, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Profile assignment -->
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Profile" Style="{StaticResource TextLabel}"/>
                    <ComboBox ItemsSource="{Binding DataContext.Profiles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              SelectedItem="{Binding DataContext.SelectedProfile, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Account assignment -->
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Account (optional)" Style="{StaticResource TextLabel}"/>
                    <ComboBox ItemsSource="{Binding DataContext.Accounts, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              SelectedItem="{Binding DataContext.SelectedAccount, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Price Threshold ($)" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.PriceThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Interval (s)" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Max Retries" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.MaxRetries, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <CheckBox Content="Enabled"       IsChecked="{Binding Selected.IsEnabled}"    Margin="0,0,0,8"/>
                <CheckBox Content="Auto Checkout" IsChecked="{Binding Selected.AutoCheckout}" Margin="0,0,0,16"
                          ToolTip="Automatically checkout when item is detected in stock"/>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Quantity" Style="{StaticResource TextLabel}"/>
                    <TextBox Text="{Binding Selected.Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Checkout Status -->
                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding Selected.AutoCheckout, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Checkout Status" Style="{StaticResource TextLabel}"/>
                    <TextBlock Text="{Binding Selected.CheckoutStatus}" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="{Binding Selected.LastOrderId, StringFormat='Order ID: {0}'}"
                               Style="{StaticResource TextCaption}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Selected.CheckoutError}"
                               Foreground="{StaticResource Danger}"
                               Style="{StaticResource TextCaption}" Margin="0,2,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Save button -->
                <Button Content="Save Task"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Left"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
