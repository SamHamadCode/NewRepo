<UserControl x:Class="MonitorBot.App.Views.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Page header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Accounts" Style="{StaticResource TextH1}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ New Account" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid DockPanel.Dock="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Account list -->
            <Border Grid.Column="0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0"
                    Background="{StaticResource BgPanel}">
                <ListBox ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         Margin="8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SiteName}" Style="{StaticResource TextCaption}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Account editor -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,20,28,20" IsEnabled="{Binding IsEditing}">

                    <TextBlock Text="ACCOUNT DETAILS" Style="{StaticResource TextLabel}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NAME" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Selected.Name, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="SITE" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Selected.SiteName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="EMAIL" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Selected.Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PASSWORD" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Selected.Password, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="2FA SECRET (optional)" Style="{StaticResource TextLabel}"/>
                        <TextBox Text="{Binding Selected.TwoFactorSecret, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <CheckBox Content="Active" IsChecked="{Binding Selected.IsActive}" Margin="0,0,0,20"/>

                    <!-- IMAP verification -->
                    <TextBlock Text="EMAIL VERIFICATION (IMAP)" Style="{StaticResource TextLabel}" Margin="0,0,0,10"/>
                    <CheckBox Content="Auto-fetch verification code from inbox"
                              IsChecked="{Binding Selected.UseEmailVerification}" Margin="0,0,0,12"/>

                    <StackPanel Visibility="{Binding Selected.UseEmailVerification,
                                    Converter={StaticResource BoolToVisibility}}">
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource TextCaption}">
                                Gmail: imap.gmail.com  port 993&#x0a;Outlook: outlook.office365.com  port 993&#x0a;Yahoo: imap.mail.yahoo.com  port 993&#x0a;&#x0a;Use an app password, not your regular password.
                            </TextBlock>
                        </Border>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="IMAP HOST" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding Selected.ImapHost, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PORT" Style="{StaticResource TextLabel}"/>
                                <TextBox Text="{Binding Selected.ImapPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Style="{StaticResource FormRow}">
                            <TextBlock Text="IMAP EMAIL (if different)" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Selected.ImapEmail, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Style="{StaticResource FormRow}">
                            <TextBlock Text="IMAP / APP PASSWORD" Style="{StaticResource TextLabel}"/>
                            <TextBox Text="{Binding Selected.ImapPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Save Account" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
