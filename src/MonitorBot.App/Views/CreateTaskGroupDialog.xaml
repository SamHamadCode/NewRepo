<Window x:Class="MonitorBot.App.Views.CreateTaskGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Create Task Group"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="{StaticResource BgPanel}"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <StackPanel>
            <!-- Dialog title bar -->
            <Border Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,12" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Create Task Group" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource WinCtrlButton}"
                            Content="&#x2715;" Click="CloseButton_Click" FontSize="11"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Form -->
            <StackPanel Margin="18,18,18,18">
                <!-- Group Name -->
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="GROUP NAME" Style="{StaticResource TextLabel}"/>
                    <TextBox x:Name="GroupNameBox" Text="New Group"
                             GotFocus="GroupNameBox_GotFocus"/>
                </StackPanel>

                <!-- Group Site -->
                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="GROUP SITE" Style="{StaticResource TextLabel}"/>
                    <ComboBox x:Name="GroupSiteBox" SelectedIndex="0">
                        <ComboBoxItem Content="Target US"/>
                        <ComboBoxItem Content="Walmart US"/>
                        <ComboBoxItem Content="Best Buy US"/>
                        <ComboBoxItem Content="Amazon US"/>
                        <ComboBoxItem Content="Costco US"/>
                        <ComboBoxItem Content="Sam's Club US"/>
                        <ComboBoxItem Content="Pokemon Center"/>
                        <ComboBoxItem Content="P-Bandai"/>
                        <ComboBoxItem Content="Footlocker US"/>
                        <ComboBoxItem Content="Nike US"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>

                <!-- Create button -->
                <Button Content="Create Task Group"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Height="38"
                        Click="CreateButton_Click"
                        Margin="0,8,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
