<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:MonitorBot.App.Converters"
    xmlns:enums="clr-namespace:MonitorBot.Core.Enums;assembly=MonitorBot.Core"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Converters -->
    <conv:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    <conv:NullToVisibilityConverter        x:Key="NullToVisibility"/>
    <conv:ZeroToVisibilityConverter        x:Key="ZeroToVisibility"/>
    <conv:NullToBoolConverter              x:Key="NullToBool"/>
    <conv:LogLevelToColorConverter         x:Key="LevelToColor"/>
    <conv:StatusToColorConverter           x:Key="StatusToColor"/>
    <conv:NavStyleSelectorConverter        x:Key="NavStyleSelector"/>
    <conv:StatusBgConverter                x:Key="StatusBgConverter"/>

    <!-- Enum sources -->
    <ObjectDataProvider x:Key="MonitorTypeValues"
                        MethodName="GetValues"
                        ObjectType="{x:Type sys:Enum}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="enums:MonitorType"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
    <ObjectDataProvider x:Key="DetectionModeValues"
                        MethodName="GetValues"
                        ObjectType="{x:Type sys:Enum}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="enums:DetectionMode"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>
    <ObjectDataProvider x:Key="NotificationChannelValues"
                        MethodName="GetValues"
                        ObjectType="{x:Type sys:Enum}">
        <ObjectDataProvider.MethodParameters>
            <x:Type TypeName="enums:NotificationChannel"/>
        </ObjectDataProvider.MethodParameters>
    </ObjectDataProvider>

    <!-- Log level strings -->
    <x:Array x:Key="LogLevelValues" Type="{x:Type sys:String}">
        <sys:String>Debug</sys:String>
        <sys:String>Information</sys:String>
        <sys:String>Warning</sys:String>
        <sys:String>Error</sys:String>
    </x:Array>

</ResourceDictionary>
